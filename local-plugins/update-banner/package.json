{
  "name": "@garlasco/update-banner",
  "version": "0.1.0",
  "description": "Toggleable top status bar (\"In aggiornamento\") with a scrolling message",
  "type": "module",
  "license": "MIT",
  "author": "Massimo Centemeri",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "preact": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "preact": "^10.28.2",
    "sass": "^1.97.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  },
  "quartz": {
    "name": "update-banner",
    "displayName": "Update Banner",
    "category": "component",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 50,
    "defaultEnabled": true,
    "defaultOptions": {
      "badge": "In aggiornamento",
      "text": "Il sito è in fase di aggiornamento — alcuni contenuti potrebbero cambiare."
    },
    "components": {
      "UpdateBanner": {
        "displayName": "Update Banner",
        "defaultPosition": "beforeBody",
        "defaultPriority": 1
      }
    },
    "optionSchema": {
      "badge": {
        "type": "string"
      },
      "text": {
        "type": "string"
      }
    }
  }
}
